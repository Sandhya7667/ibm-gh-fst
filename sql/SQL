select * from scott.emp;

select deptno, round(AVG(sal)) from scott.emp group by deptno order by deptno;

select * from scott.emp where sal>=(select round(avg(sal)) from scott.emp);

select * from scott.emp o where sal>=(select round(avg(sal)) from scott.emp i where i.deptno=o.deptno) order by deptno;

select count(empno),deptno from scott.emp group by deptno order by deptno desc;



select count(empno) as emp_count,deptno from scott.emp group by deptno order by emp_count DESC FETCH FIRST 1 ROW ONLY;

SELECT
    SELECT
    a.empno,
    a.ename,
    b.empno AS mgr_empno,
    b.ename AS mgr_name,
    c.empno AS skip_mgr_empno,
    c.ename AS skip_mgr_name
FROM scott.emp a
LEFT JOIN scott.emp b
    ON a.mgr = b.empno
LEFT JOIN scott.emp c
